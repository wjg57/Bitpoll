# customize to your needs
import re
import os

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG = False

# Language and time settings
LANGUAGE_CODE = 'de-DE'
TIME_ZONE = 'Europe/Zurich'

## Customize your instance
SITE_NAME = 'Bitpoll'
BASE_URL = 'https://poll.example.com'

# The root dir bitpoll appears to be in from the
# web, as configured in the webserver
URL_PREFIX = ''

# The domain name of the site. This is a list of
# domains accepted by the application and the host
# named as BASE_URL (and potentially localhost)
# should be in this list. You can use wildcards to
# open up access and a single '*' makes any name
# acceptable (which is not very secure, but useful
# during development ;).
ALLOWED_HOSTS = ['*']

# Url to the Base Homepage and Text on the Link,
# leave empty to not use this option
HOME_URL = "https://www.example.com"
HOME_URL_NAME = "ExAmPlE"

# If set to True, allow new users to register
REGISTER_ENABLED = True
GROUP_MANAGEMENT = REGISTER_ENABLED

# Email settings
#	Host that accepts our connections for SMTP
EMAIL_HOST = 'mail.example.com'

#	Authorization as required by the EMAIL_HOST
EMAIL_HOST_USER = 'poll@example.com'
EMAIL_HOST_PASSWORD = 'whatever'
 
#	This is the sender address visible to the
#	recipients. Note that some mail servers may
#	override this setting to identify the
#	EMAIL_HOST_USER as sender.
DEFAULT_FROM_EMAIL = 'Bitpoll <poll@example.com>'
#	Server error messages have SERVER_EMAIL as
#	sender. The note on sender addresses also
#	applies here.
SERVER_EMAIL = 'poll+admin@example.com'

#	All messages are prefixed by the following
#	text, which should make them easily identifiable.
EMAIL_SUBJECT_PREFIX = '[Bitpoll] '

#	If EMAIL_USE_TLS is set, STARTTLS is used,
#	typically on port 587. This is the most
#	frequent setup.
EMAIL_USE_TLS = True

#	If EMAIL_USE_SSL is set the whole communication
#	with the mail server is encrypted and port
#	usually is 465.
EMAIL_USE_SSL = False
#	Key and certificate files to use
EMAIL_SSL_CERTFILE = None
EMAIL_SSL_KEYFILE = None

#	Port to submit email on
#		If neither EMAIL_USE_SSL nor EMAIL_USE_TLS
#		is set you can use port 25, but this is
#		nowadays typically restricted to localhost
#		and will frequently result in mails that are
#		undeliverable to other organizations.
EMAIL_PORT = 587

EMAIL_TIMEOUT = None
EMAIL_USE_LOCALTIME =  False

